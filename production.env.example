# Configurações do Servidor para Produção
PORT=3001
NODE_ENV=production

# Configurações do PostgreSQL (Produção)
DB_HOST=seu_host_postgres_producao
DB_PORT=5432
DB_NAME=pesquisa_mercado
DB_USER=seu_usuario_producao
DB_PASSWORD=sua_senha_producao_segura

# Configurações do Pool de Conexões (Otimizadas para Produção)
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=60000
DB_POOL_IDLE=30000

# Configurações de Timeout (Otimizadas para Produção)
DB_STATEMENT_TIMEOUT=60000
DB_QUERY_TIMEOUT=60000
DB_CONNECT_TIMEOUT=60000
DB_LOCK_TIMEOUT=30000

# Logs do Banco (Desabilitado em Produção)
DB_LOGGING=false

# SSL (Desabilitado por padrão - configure conforme seu servidor)
DB_SSL=false

# Configurações JWT
JWT_SECRET=sua_chave_secreta_jwt_muito_segura_para_producao
JWT_EXPIRES_IN=24h

# Configurações de CORS (Produção)
# Separe múltiplas origens por vírgula
CORS_ORIGIN=https://pesquisa.sgr.dev.br,https://www.pesquisa.sgr.dev.br

# Configurações WhatsApp (Evolution API)
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua_api_key_producao
EVOLUTION_INSTANCE_NAME=producao
EMPRESA_WHATSAPP=5511999999999
