					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nome\": \"João Silva\",\n  \"whatsapp\": \"(11) 99999-9999\",\n  \"provedor_atual\": \"Vivo\",\n  \"satisfacao\": \"Satisfeito\",\n  \"bairro\": \"Centro\",\n  \"velocidade\": \"100 Mbps\",\n  \"valor_mensal\": \"R$ 89,90\",\n  \"uso_internet\": \"Trabalho, Netflix, jogos online\",\n  \"interesse_proposta\": \"Sim, tenho interesse\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/pesquisas",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"pesquisas"
